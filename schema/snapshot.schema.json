    "Inference": {
      "description": "HMM-derived state inference.\n\nPer 5w0.6, populated only after the shadow review (Phase 3+). During Phase 1\nthis field stays None on every entity status object.",
      "properties": {
        "condition": {
          "title": "Condition",
          "type": "string"
        },
        "is_disrupted": {
          "title": "Is Disrupted",
          "type": "boolean"
        },
        "model_warming_up": {
          "default": false,
          "title": "Model Warming Up",
          "type": "boolean"
        },
        "overdue": {
          "default": false,
          "title": "Overdue",
          "type": "boolean"
        },
        "p_disrupted": {
          "title": "P Disrupted",
          "type": "number"
        },
        "p_normal": {
          "title": "P Normal",
          "type": "number"
        },
        "p_normal_in_120min": {
          "title": "P Normal In 120Min",
          "type": "number"
        },
        "p_normal_in_30min": {
          "title": "P Normal In 30Min",
          "type": "number"
        },
        "p_normal_in_60min": {
          "title": "P Normal In 60Min",
          "type": "number"
        },
        "p_suspended": {
