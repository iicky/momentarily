# Phase B (the Models tab) reads the prediction/transition history directly from
# R2 over the S3 API. Copy this to .env.local and fill in.
#
# Mint these in the Cloudflare dashboard: R2 → Manage R2 API Tokens →
# "Create API token" (Object Read is enough). The Workers deploy token can't
# read objects, so this is a separate credential.

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# R2_BUCKET=momentarily   # override only if your bucket name differs

# Phase A (the Status tab) needs no credentials — it reads the public snapshot.
# Override the feed origin only for local/staging Workers:
# NEXT_PUBLIC_FEED_BASE=https://feed.momentarily.nyc
