        "service_irregularity_summaries": {
          "anyOf": [
            {
              "$ref": "#/$defs/CompatRouteSummary"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "status": {
          "title": "Status",
          "type": "string"
        }
      },
      "required": [
        "id",
        "name",
        "color",
        "status"
      ],
      "title": "CompatRoute",
      "type": "object"
    },
    "CompatRouteSummary": {
      "description": "Legacy compat: matches homeassistant-mta-subway's DirectionalStatus.",
      "properties": {
        "north": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "North"
        },
        "south": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "South"
        }
      },
      "title": "CompatRouteSummary",
      "type": "object"
    },
    "CompatServiceChangeSummary": {
      "description": "Legacy compat: matches homeassistant-mta-subway's ServiceChangeSummary.",
