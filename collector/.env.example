# The JSON feeds the collector polls (camsys/subway-alerts.json, nyct/nyct_ene.json,
# nyct/nyct_ene_upcoming.json) are publicly accessible from api-endpoint.mta.info
# without authentication. So no API key is required for v1 of the collector.
#
# This file exists for future expansion: when we eventually add protobuf feeds
# (trip updates, vehicle positions) for arrival ETAs, those WILL require an MTA
# API key set as MTA_API_KEY here.
#
# Get a free key at https://api.mta.info — registration takes ~2 minutes.

# MTA_API_KEY=

# Optional overrides — defaults are sensible
# POLL_INTERVAL_SECONDS=300       # subway alerts: every 5 minutes
# ENE_POLL_INTERVAL_SECONDS=3600  # E&E: every hour
# LOG_LEVEL=INFO
