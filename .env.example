# Momentarily — environment for self-hosting (see docs/self-hosting.md).
#
# The iicky-operated instance keeps these in an encrypted `murk` vault and the
# npm scripts wrap wrangler in `murk exec`. You do NOT need murk: copy this to
# `.env`, fill it in, `source .env`, and run wrangler / the Python tools
# directly. (`.env` is gitignored.)

# Cloudflare account that owns the Worker, R2 bucket, and trainer Container.
# Read by wrangler at deploy time.
CLOUDFLARE_ACCOUNT_ID=

# R2 S3 credentials — used by the weekly trainer Container and the eval job to
# read/write state. Create an R2 API token in the Cloudflare dashboard
# (Account → R2 → Manage API Tokens). For the deployed trainer, prefer
# `wrangler secret put R2_*` over env vars; these are for local runs.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=my-momentarily

# No MTA API key is required — the upstream feeds are served keyless.
