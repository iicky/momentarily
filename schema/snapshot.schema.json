            "$ref": "#/$defs/TimeRange"
          },
          "title": "Active Period",
          "type": "array"
        },
        "alert_type": {
          "title": "Alert Type",
          "type": "string"
        },
        "created_at": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Created At"
        },
        "description_text": {
          "anyOf": [
            {
              "$ref": "#/$defs/TranslatedString"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "display_before_active": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Display Before Active"
        },
        "header_text": {
          "anyOf": [
            {
              "$ref": "#/$defs/TranslatedString"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "id": {
          "title": "Id",
          "type": "string"
        },
        "informed_entities": {
          "default": [],
          "items": {
            "$ref": "#/$defs/InformedEntity"
          },
          "title": "Informed Entities",
          "type": "array"
        },
        "sort_order": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Sort Order"
        },
        "source": {
          "$ref": "#/$defs/AlertSource"
        },
        "updated_at": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Updated At"
        }
      },
      "required": [
        "id",
        "alert_type",
        "source"
      ],
      "title": "Alert",
      "type": "object"
    },
    "AlertSource": {
      "type": "string"
    },
    "Bridge": {
      "description": "Infrastructure asset. Schema scaffold; populated when a data source is wired.",
