          "type": "boolean"
        },
        "recovery_minutes": {
          "title": "Recovery Minutes",
          "type": "integer"
        },
        "recovery_minutes_high": {
          "title": "Recovery Minutes High",
          "type": "integer"
        },
        "recovery_minutes_low": {
          "title": "Recovery Minutes Low",
          "type": "integer"
        },
        "recovery_source": {
          "default": "hmm",
          "title": "Recovery Source",
          "type": "string"
        },
        "regime_age_seconds": {
          "title": "Regime Age Seconds",
          "type": "integer"
        },
        "regime_entered_at": {
          "title": "Regime Entered At",
          "type": "integer"
        },
        "resumes_at": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Resumes At"
        }
      },
      "required": [
        "condition",
        "recovery_minutes",
        "is_disrupted",
        "p_normal",
        "p_disrupted",
        "p_suspended",
        "regime_entered_at",
        "regime_age_seconds",
        "recovery_minutes_low",
        "recovery_minutes_high",
        "p_normal_in_30min",
        "p_normal_in_60min",
        "p_normal_in_120min"
      ],
      "title": "Inference",
      "type": "object"
