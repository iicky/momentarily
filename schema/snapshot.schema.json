    "Observation": {
      "description": "Continuous / instantaneous measurement of an entity.\n\nPeer to Alert. Empty in v1 of the publisher; populated when we wire upstream\nsources for travel-time (bridges/tunnels), headway, ETAs, tolls, occupancy.",
      "properties": {
        "entity_ref": {
          "title": "Entity Ref",
          "type": "string"
        },
        "kind": {
          "title": "Kind",
          "type": "string"
        },
        "observed_at": {
          "title": "Observed At",
          "type": "integer"
        },
        "source": {
          "title": "Source",
          "type": "string"
        },
        "unit": {
          "title": "Unit",
          "type": "string"
        },
        "value": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "integer"
            },
            {
              "type": "string"
            }
          ],
          "title": "Value"
        }
      },
      "required": [
        "entity_ref",
        "kind",
        "value",
        "unit",
        "observed_at",
        "source"
      ],
      "title": "Observation",
      "type": "object"
    },
