        },
        "operator": {
          "title": "Operator",
          "type": "string"
        }
      },
      "required": [
        "id",
        "name",
        "operator"
      ],
      "title": "Bridge",
      "type": "object"
    },
    "Compat": {
      "description": "Legacy surfaces, derived from canonical types above.",
      "properties": {
        "subwaynow_routes": {
          "additionalProperties": {
            "$ref": "#/$defs/CompatRoute"
          },
          "title": "Subwaynow Routes",
          "type": "object"
        }
      },
      "title": "Compat",
      "type": "object"
    },
    "CompatRoute": {
      "description": "Legacy compat: matches homeassistant-mta-subway's Route exactly.\n\nProduced so existing HA installs can swap API_URL with zero code change\nand continue reading subway state from this snapshot.",
      "properties": {
        "color": {
          "title": "Color",
          "type": "string"
        },
        "delay_summaries": {
          "anyOf": [
            {
              "$ref": "#/$defs/CompatRouteSummary"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "direction_statuses": {
          "anyOf": [
            {
              "$ref": "#/$defs/CompatRouteSummary"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "id": {
          "title": "Id",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "scheduled": {
          "default": true,
          "title": "Scheduled",
          "type": "boolean"
        },
        "service_change_summaries": {
          "anyOf": [
            {
              "$ref": "#/$defs/CompatServiceChangeSummary"
            },
            {
              "type": "null"
            }
          ],
          "default": null
